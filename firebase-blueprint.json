{
  "entities": {
    "Employee": {
      "title": "Employee",
      "description": "A company employee with HR details",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name" },
        "role": { "type": "string", "enum": ["Gerente", "Senior", "Pleno", "Junior", "Estagiário"], "description": "Seniority level" },
        "position": { "type": "string", "description": "Job title/function" },
        "section": { "type": "string", "description": "Department/Section" },
        "salary": { "type": "number", "description": "Monthly salary in BRL" },
        "status": { 
          "type": "string", 
          "enum": ["Disponível", "Tratamento de Saúde", "Férias", "Viagem a Trabalho", "Na Empresa", "Home Office", "Fora de Expediente", "Atestado"],
          "description": "Current availability status"
        },
        "performance": { "type": "number", "description": "Performance score 1-10" },
        "complaints": { "type": "number", "description": "Number of complaints" },
        "medicalCertificatesCount": { "type": "number", "description": "Total number of medical certificates" },
        "area": { "type": "string", "description": "Professional area" },
        "uid": { "type": "string", "description": "Owner UID" }
      },
      "required": ["name", "role", "position", "section", "salary", "status", "area", "uid"]
    },
    "Expense": {
      "title": "Expense",
      "description": "Company operational expense",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["API", "Cloud", "Licença", "Água", "Luz", "Internet", "Outros"], "description": "Expense category" },
        "amount": { "type": "number", "description": "Monetary value" },
        "currency": { "type": "string", "enum": ["USD", "EUR", "BRL"], "description": "Currency code" },
        "date": { "type": "string", "format": "date-time", "description": "Date of expense" },
        "description": { "type": "string", "description": "Optional details" },
        "uid": { "type": "string", "description": "Owner UID" }
      },
      "required": ["type", "amount", "currency", "date", "uid"]
    },
    "CompanyPortfolio": {
      "title": "CompanyPortfolio",
      "description": "Marketing and branding profile for the company",
      "type": "object",
      "properties": {
        "companyName": { "type": "string" },
        "tagline": { "type": "string" },
        "description": { "type": "string" },
        "logoUrl": { "type": "string" },
        "mission": { "type": "string" },
        "vision": { "type": "string" },
        "values": { "type": "array", "items": { "type": "string" } },
        "milestones": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "year": { "type": "string" },
              "title": { "type": "string" },
              "description": { "type": "string" }
            }
          } 
        },
        "uid": { "type": "string" }
      },
      "required": ["companyName", "uid"]
    }
  },
  "firestore": {
    "/employees/{employeeId}": {
      "schema": "Employee",
      "description": "Collection of employees"
    },
    "/expenses/{expenseId}": {
      "schema": "Expense",
      "description": "Collection of company expenses"
    },
    "/inventory/{itemId}": {
      "schema": "InventoryItem",
      "description": "Company inventory items"
    },
    "/revenue/{recordId}": {
      "schema": "RevenueRecord",
      "description": "Income and outcome records"
    },
    "/subscriptions/{subId}": {
      "schema": "Subscription",
      "description": "User subscription status"
    },
    "/portfolios/{portfolioId}": {
      "schema": "CompanyPortfolio",
      "description": "Company marketing portfolios"
    }
  }
}
